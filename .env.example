# Copy this file to .env and fill in the values
# Never commit .env to git

# Your domain (Caddy uses this for automatic SSL)
DOMAIN=expensebeam.com

# PostgreSQL password — use a strong random string
DB_PASSWORD=change_this_strong_password

# JWT secret — generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_64_char_random_string

# Server-side Claude API key used for all AI features (expense parsing, Finance Chat, insights)
ANTHROPIC_API_KEY=

# Telegram bot (optional — leave blank to disable the Telegram integration)
# Create a bot with @BotFather to get the token + username
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
# Random string used as a secret path segment for the webhook URL
TELEGRAM_WEBHOOK_SECRET=

# Google Play subscription verification (required for the mobile app's Pro plan purchase flow)
# Service account JSON (single-line) for a service account with access to the Play Console API
GOOGLE_SERVICE_ACCOUNT_JSON=
# Android package name, e.g. com.expensebeam.expensebeam_mobile
GOOGLE_PLAY_PACKAGE=
# Play Console subscription product id, e.g. expensebeam_pro_monthly
GOOGLE_PLAY_SUBSCRIPTION_ID=
